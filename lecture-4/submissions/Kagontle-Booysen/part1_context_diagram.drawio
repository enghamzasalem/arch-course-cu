        <mxCell id="QrU47V-_piiqtoeeVpsh-230" parent="1" style="text;whiteSpace=wrap;html=1;" value="Subscribers search the catalog, play videos in adaptive quality (HLS/DASH), manage their watchlist and viewing history, and receive personalized recommendations via web, mobile, or smart TV." vertex="1">
          <mxGeometry height="40" width="560" x="500" y="850" as="geometry" />
        </mxCell>
        <mxCell id="QrU47V-_piiqtoeeVpsh-231" parent="1" style="text;whiteSpace=wrap;html=1;" value="Content creators upload video files, provide metadata (title, description, tags), and monitor view analytics through a creator dashboard." vertex="1">
          <mxGeometry height="40" width="570" x="500" y="890" as="geometry" />
        </mxCell>
        <mxCell id="QrU47V-_piiqtoeeVpsh-232" parent="1" style="text;whiteSpace=wrap;html=1;" value="Admins moderate content, manage user accounts and subscriptions, configure recommendation algorithms, and monitor system health via an internal admin console." vertex="1">
          <mxGeometry height="50" width="560" x="505" y="930" as="geometry" />
        </mxCell>
        <mxCell id="QrU47V-_piiqtoeeVpsh-233" parent="1" style="text;whiteSpace=wrap;html=1;" value="The platform initiates payment charges and recurring subscription renewals via the Payment Gateway API (Stripe / Braintree) and receives webhook callbacks for payment status." vertex="1">
          <mxGeometry height="50" width="560" x="505" y="970" as="geometry" />
        </mxCell>
        <mxCell id="QrU47V-_piiqtoeeVpsh-234" parent="1" style="text;whiteSpace=wrap;html=1;" value="Encoded video segments, thumbnails, and subtitles are pushed to CDN edge nodes. The platform generates signed URLs so subscribers stream directly from the nearest CDN PoP, reducing latency." vertex="1">
          <mxGeometry height="70" width="560" x="505" y="1010" as="geometry" />
        </mxCell>
        <mxCell id="QrU47V-_piiqtoeeVpsh-235" parent="1" style="text;whiteSpace=wrap;html=1;" value="The platform triggers transactional emails (welcome, billing receipts, password reset) and push notifications (new content, continue watching reminders) via SendGrid / FCM." vertex="1">
          <mxGeometry height="50" width="560" x="505" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="QrU47V-_piiqtoeeVpsh-236" parent="1" style="text;whiteSpace=wrap;html=1;" value="Users authenticate via OAuth 2.0 / OpenID Connect (social login, SSO). The platform delegates token issuance and session management to Auth0 / Okta and validates JWTs on each request." vertex="1">
          <mxGeometry height="50" width="560" x="505" y="1090" as="geometry" />
        </mxCell>
