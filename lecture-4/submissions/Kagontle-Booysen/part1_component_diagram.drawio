  <diagram id="a1frov7Uv-1z-NQmQTI0" name="Page-2">
    <mxGraphModel dx="1141" dy="594" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="k8F4zPAXFyrzUgs0gDBM-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;b&gt;&lt;font style=&quot;font-size: 30px;&quot;&gt;Components&lt;br&gt;&lt;/font&gt;&lt;br&gt;C1 · API Handler&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Python · gRPC Server]&lt;br&gt;&lt;br&gt;Receives recommendation requests, validates inputs, checks Result Cache, and orchestrates the retrieval pipeline.&lt;br&gt;&lt;br&gt;&lt;b&gt;C2 · Feature Store&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Python · PostgreSQL client]&lt;br&gt;&lt;br&gt;Builds feature vectors from user watch history, ratings, and content metadata stored in PostgreSQL.&lt;br&gt;&lt;br&gt;&lt;b&gt;C3 · Candidate Generator&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Python · FAISS ANN index]&lt;br&gt;&lt;br&gt;Performs approximate nearest-neighbour search to retrieve a pool of candidate videos from the embedding index.&lt;br&gt;&lt;br&gt;&lt;b&gt;C4 · Ranking Model&lt;/b&gt;&lt;br&gt;&lt;br&gt;[TensorFlow Serving · gRPC]&lt;br&gt;&lt;br&gt;Scores each candidate using a trained neural ranking model and returns a sorted list to the API Handler.&lt;br&gt;&lt;br&gt;&lt;b&gt;C5 · Result Cache&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Python · Redis client]&lt;br&gt;&lt;br&gt;Caches ranked recommendation lists per user (TTL 5 min) to avoid full pipeline re-execution on repeat calls.&lt;br&gt;&lt;br&gt;&lt;b&gt;C6 · Event Logger&lt;/b&gt;&lt;br&gt;&lt;br&gt;[Python · Kafka producer]&lt;br&gt;&lt;br&gt;Publishes impression and click-through events to Kafka so the ML team can retrain models on fresh feedback.&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(107, 114, 128); font-family: Inter, sans-serif; letter-spacing: 0.8px; text-transform: uppercase; background-color: rgb(245, 246, 250);&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;// Component Dependencies&lt;/font&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;table style=&quot;margin: 0px; padding: 0px; width: 1238.23px; border-collapse: collapse; background: rgb(255, 255, 255); border: 1px solid rgb(221, 225, 236); border-radius: 8px; overflow: hidden; color: rgb(26, 29, 46); font-family: Inter, sans-serif;&quot;&gt;&lt;thead style=&quot;box-sizing: border-box; margin: 0px; padding: 0px;&quot;&gt;&lt;tr style=&quot;box-sizing: border-box; margin: 0px; padding: 0px;&quot;&gt;&lt;th style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; background: rgb(249, 250, 251); text-align: left; font-size: 10px; text-transform: uppercase; letter-spacing: 0.6px; color: rgb(107, 114, 128); border-bottom: 1px solid rgb(221, 225, 236);&quot;&gt;#&lt;/th&gt;&lt;th style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; background: rgb(249, 250, 251); text-align: left; font-size: 10px; text-transform: uppercase; letter-spacing: 0.6px; color: rgb(107, 114, 128); border-bottom: 1px solid rgb(221, 225, 236);&quot;&gt;From&lt;/th&gt;&lt;th style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; background: rgb(249, 250, 251); text-align: left; font-size: 10px; text-transform: uppercase; letter-spacing: 0.6px; color: rgb(107, 114, 128); border-bottom: 1px solid rgb(221, 225, 236);&quot;&gt;→ To&lt;/th&gt;&lt;th style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; background: rgb(249, 250, 251); text-align: left; font-size: 10px; text-transform: uppercase; letter-spacing: 0.6px; color: rgb(107, 114, 128); border-bottom: 1px solid rgb(221, 225, 236);&quot;&gt;Protocol&lt;/th&gt;&lt;th style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; background: rgb(249, 250, 251); text-align: left; font-size: 10px; text-transform: uppercase; letter-spacing: 0.6px; color: rgb(107, 114, 128); border-bottom: 1px solid rgb(221, 225, 236);&quot;&gt;Description&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody style=&quot;box-sizing: border-box; margin: 0px; padding: 0px;&quot;&gt;&lt;tr style=&quot;box-sizing: border-box; margin: 0px; padding: 0px;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;1&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;API Gateway&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C1 API Handler&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;&lt;span class=&quot;tag&quot; style=&quot;box-sizing: border-box; margin: 0px 4px 0px 0px; padding: 1px 7px; display: inline-block; border-radius: 4px; font-size: 10px; font-weight: 600; background: rgb(219, 234, 254); color: rgb(29, 78, 216);&quot;&gt;gRPC&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;Forwards getRecs(userId, limit) calls from the User Service or client apps&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;box-sizing: border-box; margin: 0px; padding: 0px;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;2&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;User Service&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C2 Feature Store&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;&lt;span class=&quot;tag&quot; style=&quot;box-sizing: border-box; margin: 0px 4px 0px 0px; padding: 1px 7px; display: inline-block; border-radius: 4px; font-size: 10px; font-weight: 600; background: rgb(219, 234, 254); color: rgb(29, 78, 216);&quot;&gt;gRPC&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;Pushes user watch history and ratings events so Feature Store can refresh its vectors&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;box-sizing: border-box; margin: 0px; padding: 0px;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;3&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C1 API Handler&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C5 Result Cache&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;&lt;span class=&quot;tag&quot; style=&quot;box-sizing: border-box; margin: 0px 4px 0px 0px; padding: 1px 7px; display: inline-block; border-radius: 4px; font-size: 10px; font-weight: 600; background: rgb(204, 251, 241); color: rgb(15, 118, 110);&quot;&gt;Redis&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;Checks for a cached ranked list before invoking the full retrieval pipeline&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;box-sizing: border-box; margin: 0px; padding: 0px;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;4&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C1 API Handler&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C2 Feature Store&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;&lt;span class=&quot;tag&quot; style=&quot;box-sizing: border-box; margin: 0px 4px 0px 0px; padding: 1px 7px; display: inline-block; border-radius: 4px; font-size: 10px; font-weight: 600; background: rgb(243, 232, 255); color: rgb(109, 40, 217);&quot;&gt;fn call&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;Requests assembled feature vector for the requesting user&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;box-sizing: border-box; margin: 0px; padding: 0px;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;5&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C1 API Handler&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C3 Candidate Generator&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;&lt;span class=&quot;tag&quot; style=&quot;box-sizing: border-box; margin: 0px 4px 0px 0px; padding: 1px 7px; display: inline-block; border-radius: 4px; font-size: 10px; font-weight: 600; background: rgb(243, 232, 255); color: rgb(109, 40, 217);&quot;&gt;fn call&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;Dispatches feature vector to retrieve top-N candidate video IDs via ANN search&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;box-sizing: border-box; margin: 0px; padding: 0px;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top; background: rgb(249, 250, 251);&quot;&gt;6&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top; background: rgb(249, 250, 251);&quot;&gt;C2 Feature Store&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top; background: rgb(249, 250, 251);&quot;&gt;PostgreSQL&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top; background: rgb(249, 250, 251);&quot;&gt;&lt;span class=&quot;tag&quot; style=&quot;box-sizing: border-box; margin: 0px 4px 0px 0px; padding: 1px 7px; display: inline-block; border-radius: 4px; font-size: 10px; font-weight: 600; background: rgb(254, 249, 195); color: rgb(133, 77, 14);&quot;&gt;SQL&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top; background: rgb(249, 250, 251);&quot;&gt;Reads user history, watch-time, and content metadata tables to build feature vectors&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;box-sizing: border-box; margin: 0px; padding: 0px;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;7&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C3 Candidate Generator&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C4 Ranking Model&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;&lt;span class=&quot;tag&quot; style=&quot;box-sizing: border-box; margin: 0px 4px 0px 0px; padding: 1px 7px; display: inline-block; border-radius: 4px; font-size: 10px; font-weight: 600; background: rgb(243, 232, 255); color: rgb(109, 40, 217);&quot;&gt;fn call&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;Passes candidate list + feature vector; receives scores and sorted order back&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;box-sizing: border-box; margin: 0px; padding: 0px;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;8&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C4 Ranking Model&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C5 Result Cache&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;&lt;span class=&quot;tag&quot; style=&quot;box-sizing: border-box; margin: 0px 4px 0px 0px; padding: 1px 7px; display: inline-block; border-radius: 4px; font-size: 10px; font-weight: 600; background: rgb(204, 251, 241); color: rgb(15, 118, 110);&quot;&gt;Redis&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;Writes the final ranked list into Redis with a 5-minute TTL keyed by userId&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;box-sizing: border-box; margin: 0px; padding: 0px;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;9&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C4 Ranking Model&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C6 Event Logger&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;&lt;span class=&quot;tag&quot; style=&quot;box-sizing: border-box; margin: 0px 4px 0px 0px; padding: 1px 7px; display: inline-block; border-radius: 4px; font-size: 10px; font-weight: 600; background: rgb(243, 232, 255); color: rgb(109, 40, 217);&quot;&gt;fn call&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;Notifies Event Logger of each impression (which videos were shown to the user)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;box-sizing: border-box; margin: 0px; padding: 0px;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;10&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;C5 Result Cache&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;Redis Cache&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; margin: 0px; padding: 9px 14px; border-bottom: 1px solid rgb(240, 242, 248); color: rgb(55, 65, 81); vertical-align: top;&quot;&gt;&lt;span class=&quot;tag&quot; style=&quot;box-sizing: border-box; margin: 0px 4px 0px 0px; padding: 1px 7px; display: inline-block; border-radius: 4px; font-size: 10px; font-weight: 600; background: rgb(204, 251, 241); color: rgb(15, 118, 110);&quot;&gt;Redis&lt;/span&gt;&lt;/td&gt;&lt;td style=&quot;box