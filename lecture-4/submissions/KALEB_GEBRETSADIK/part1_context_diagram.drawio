        <!-- Video Streaming Platform (System) -->
        <mxCell id="vsp" value="&lt;b&gt;Video Streaming Platform&lt;/b&gt;&lt;br/&gt;[Software System]&lt;br/&gt;&lt;br/&gt;Allows users to watch videos, upload content, and get recommendations." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168bd;fontColor=#ffffff;strokeColor=#00509B;align=center;verticalAlign=middle;" vertex="1" parent="1">
