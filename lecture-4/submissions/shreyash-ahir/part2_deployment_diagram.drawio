        <mxCell id="jYgu-oSVlayiNDzByuDm-36" parent="1" style="html=1;align=center;verticalAlign=middle;dashed=0;whiteSpace=wrap;" value="&amp;lt;&amp;lt;artifact&amp;gt;&amp;gt;&lt;br&gt;&lt;br&gt;VideoAssets.mp4" vertex="1">
