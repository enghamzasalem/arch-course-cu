  <diagram name="Page-1" id="zyBUORyuxwfiTn_9xa07">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    %% Components\n    Client[\&quot;Client - Web / API / Batch\&quot;]\n    Validator[\&quot;Validator - checks document format and required fields\&quot;]\n    Extractor[\&quot;Extractor / OCR - extracts text or OCR\&quot;]\n    Classifier[\&quot;Classifier - determines document type\&quot;]\n    Storage[\&quot;Storage Service - stores document and metadata\&quot;]\n    Notifier[\&quot;Notifier - sends notification when done\&quot;]\n\n    %% Connectors\n    Client --&gt;|Upload or API call - REST sync| Validator\n    Validator --&gt;|Validated document - direct call sync| Extractor\n    Extractor --&gt;|Extracted text - direct call sync| Classifier\n    Classifier --&gt;|Classified document - direct call sync| Storage\n    Storage --&gt;|Stored confirmation - message queue async| Notifier\n\n    %% Optional: legend (colors for sync/async)\n    classDef sync fill:#a2d2ff,stroke:#1d3557,stroke-width:1px\n    classDef async fill:#ffb4a2,stroke:#1d3557,stroke-width:1px\n\n    class Validator,Extractor,Classifier sync\n    class Storage,Notifier async&quot;&#xa;}" id="oIAn53Xd7sMnmmrSdi8z-14">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;imageAspect=1;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="934.5" width="640" x="50" y="-190" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="oIAn53Xd7sMnmmrSdi8z-15" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;h3 tabindex=&quot;-1&quot; class=&quot;heading-element&quot; dir=&quot;auto&quot; style=&quot;box-sizing: border-box; margin-top: 24px; margin-bottom: 16px; line-height: 1.25; color: rgb(240, 246, 252); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Noto Sans&amp;quot;, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;; text-align: start; background-color: rgb(13, 17, 23);&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;Component and Connector Diagram&lt;/font&gt;&lt;/h3&gt;" vertex="1">
