  <diagram name="Page-1" id="TaQBmZLjoEkkJBl46MRq">
    <mxGraphModel dx="976" dy="1767" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n\n    %% COMPONENTS\n    Client[\&quot;Client (Web / API / Batch)\&quot;]\n    API[\&quot;API Gateway\&quot;]\n    Validator[\&quot;Validator\&quot;]\n    Extractor[\&quot;Extractor (OCR / Text)\&quot;]\n    Classifier[\&quot;Classifier\&quot;]\n    Storage[\&quot;Storage Service\&quot;]\n    Notifier[\&quot;Notifier\&quot;]\n\n    Queue[(Message Queue)]\n    EventBus[(Event Bus)]\n\n    %% SYNC PART\n    Client --&gt;|\&quot;HTTP (sync)\&quot;| API\n    API --&gt;|\&quot;Validate (sync)\&quot;| Validator\n\n    %% ASYNC PIPELINE\n    Validator --&gt;|\&quot;Send to queue (async)\&quot;| Queue\n    Queue --&gt; Extractor\n\n    Extractor --&gt;|\&quot;Send to queue (async)\&quot;| Queue\n    Queue --&gt; Classifier\n\n    Classifier --&gt;|\&quot;Send to queue (async)\&quot;| Queue\n    Queue --&gt; Storage\n\n    %% EVENT-DRIVEN NOTIFICATION\n    Storage --&gt;|\&quot;Publish event\&quot;| EventBus\n    EventBus --&gt; Notifier\n\n    %% LEGEND\n    subgraph LEGEND[\&quot;Legend\&quot;]\n        direction LR\n        L1[\&quot;Sync (HTTP / Direct Call)\&quot;]\n        L2[\&quot;Async (Message Queue)\&quot;]\n        L3[\&quot;Event-driven (Event Bus)\&quot;]\n    end&quot;&#xa;}" id="5">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;imageAspect=1;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1340" width="997.4" x="10" y="-260" as="geometry" />
          </mxCell>
        </UserObject>
